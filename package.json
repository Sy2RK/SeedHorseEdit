{
  "name": "seed-horse-edit-tool",
  "version": "1.0.0",
  "description": "Local web tool for HappyHorse 1.0 and Seedance 2.0 video editing calls.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.server.json && tsc -p tsconfig.client.json",
    "dev": "npm run build && node dist/server.js",
    "start": "node dist/server.js",
    "check": "npm run build"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
